# Copier ce fichier en .env et remplir les valeurs

# Clé API Anthropic (obligatoire)
# Obtenir sur https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Pour la production HTTPS uniquement (docker-compose.prod.yml)
DOMAIN=cv-scorer.votredomaine.com
ACME_EMAIL=admin@votredomaine.com

# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Rate limiting (requêtes par minute par IP)
RATE_LIMIT_PER_MINUTE=10

# Token d'authentification optionnel (laisser vide pour désactiver)
API_TOKEN=

# En production exposée : exiger un token (1/true). API_TOKEN doit alors être défini.
REQUIRE_API_TOKEN=

# Analyse en 2 passes (extraction JSON puis score) — plus fiable, ~2× appels API et ~2× coût tokens
# Laisser vide ou 0/false pour une seule passe (recommandé pour limiter la consommation).
CLAUDE_TWO_PASS=

# Cache de prompt Anthropic (1/true) : fortement recommandé — le bloc d'instructions est réutilisé entre CV (tarif cache lecture).
CLAUDE_PROMPT_CACHE=1

# Taille minimale du bloc mis en cache (caractères, défaut 4096). Ne pas baisser sans vérifier la doc API cache.
# PROMPT_CACHE_MIN_CHARS=

# Tronquer le texte extrait du CV avant l'appel Claude (caractères, défaut 3000). Baisser (ex. 2000) pour économiser des tokens.
CV_TEXT_MAX_CHARS=

# Build frontend : token envoyé dans Authorization (optionnel, même valeur que API_TOKEN)
# REACT_APP_API_TOKEN=
